# === LLM Tier Configuration ===
# Tier 1: Free/Cheap — routing, classification, formatting
TIER1_PROVIDER=groq
GROQ_API_KEY=gsk_your_key_here

# Tier 2: Cheap — content generation, drafts
TIER2_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk_your_key_here
# DeepSeek uses OpenAI-compatible API: https://api.deepseek.com/v1

# Tier 3: Quality — final polish, complex creative (use sparingly)
TIER3_PROVIDER=claude
ANTHROPIC_API_KEY=sk-ant-your_key_here

# === Image Generation ===
# Ideogram API (optional — system works without it using placeholders)
IDEOGRAM_API_KEY=your_key_here

# === RAG ===
CHROMA_PERSIST_DIR=./chroma_db

# === App ===
CAMPAIGN_OUTPUTS_DIR=./outputs
LOG_LEVEL=INFO

# === WhatsApp (replace with your real number) ===
WHATSAPP_NUMBER=8801XXXXXXXXX
